{
  "name": "facial-measurement-api",
  "version": "1.0.0",
  "description": "AI-Based Real-Time 3D Facial Measurement Backend System",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "node test/test-api.js",
    "test:accuracy": ".venv/bin/python test/accuracy_test_100.py",
    "test:pd": ".venv/bin/python test/pd_3way_comparison.py",
    "setup-python": ".venv/bin/pip install -r python/requirements.txt",
    "setup-venv": "python3 -m venv .venv && .venv/bin/pip install --upgrade pip && .venv/bin/pip install -r python/requirements.txt"
  },
  "keywords": [
    "facial-measurement",
    "mediapipe",
    "3d-landmarks",
    "computer-vision"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}
