# Environment
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# Python — absolute path to your venv python: /path/to/.venv/bin/python (Linux/Mac) or C:\path\.venv\Scripts\python.exe (Windows)
# Use a unique name to avoid conflict with system PYTHON_PATH env var
FACE_PYTHON=/home/codespace/finalproject/.venv/bin/python

# CORS — set specific origins in production, e.g.: http://localhost:3000,https://yourdomain.com
CORS_ORIGINS=*

# Upload limit (bytes) — default 10MB
# MAX_FILE_SIZE=10485760
